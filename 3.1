#include <cstddef>
#include <cstring>
#include <iostream>

template <typename T>
T max(T a, T b)
{
    return (a > b) ? a : b;
}

template <typename T>
T* max(T* a, T* b)
{
    if (a == nullptr)
    {
        return b;
    }

    if (b == nullptr)
    {
        return a;
    }

    return (*a > *b) ? a : b;
}

template <typename T>
T* max(T* data, std::size_t n)
{
    if (data == nullptr || n == 0)
    {
        return nullptr;
    }

    T* best = &data[0];

    for (std::size_t i = 1; i < n; ++i)
    {
        if (data[i] > *best)
        {
            best = &data[i];
        }
    }

    return best;
}

char* max(char* a, char* b)
{
    if (a == nullptr)
    {
        return b;
    }

    if (b == nullptr)
    {
        return a;
    }

    return (std::strcmp(a, b) > 0) ? a : b;
}

const char* max(const char* a, const char* b)
{
    if (a == nullptr)
    {
        return b;
    }

    if (b == nullptr)
    {
        return a;
    }

    return (std::strcmp(a, b) > 0) ? a : b;
}

const char* max(char* a, const char* b)
{
    if (a == nullptr)
    {
        return b;
    }

    if (b == nullptr)
    {
        return a;
    }

    return (std::strcmp(a, b) > 0) ? a : b;
}

int main()
{
    std::cout << "max(3, 7) = " << max(3, 7) << "\n";

    int x = 10;
    int y = 25;
    int* bigger_ptr = max(&x, &y);
    std::cout << "wiekszy przez wskaznik = " << *bigger_ptr << "\n";

    int tab[] = {4, 9, 1, 13, 5};
    int* biggest_in_array = max(tab, 5);
    if (biggest_in_array != nullptr)
    {
        std::cout << "najwiekszy w tablicy = " << *biggest_in_array << "\n";
    }

    char a[] = "kot";
    char b[] = "zebra";
    std::cout << "wiekszy napis char* = " << max(a, b) << "\n";

    const char* c = "banan";
    const char* d = "arbuz";
    std::cout << "wiekszy napis const char* = " << max(c, d) << "\n";

    std::cout << "wersja mieszana = " << max(a, "lama") << "\n";

    return 0;
}
