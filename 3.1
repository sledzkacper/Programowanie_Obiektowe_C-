#include <cstddef>
#include <cstring>
#include <iostream>
using namespace std;

template <typename T>
T max(T a, T b)
{
    return (a > b) ? a : b;
}

template <typename T>
T* max(T* a, T* b)
{
    return (*a > *b) ? a : b;
}


template <typename T>
T* max(T* data, size_t n)   // Wersja dla tablicy 
{
    T* najwiekszy = &data[0];

    for (size_t i = 1; i < n; ++i)
    {
        if (data[i] > *najwiekszy)
        {
            najwiekszy = &data[i];
        }
    }

    return najwiekszy;
}

char* max(char* a, char* b)
{
    return (strcmp(a, b) > 0) ? a : b; // Trzeba użyć funkcji string compare, bo inaczej porównujemy adresy
}

const char* max(const char* a, const char* b)   // Wersja niemodyfikowalnych napisów
{
    return (strcmp(a, b) > 0) ? a : b;  
}

const char* max(char* a, const char* b)
{
    return (strcmp(a, b) > 0) ? a : b;
}

int main()  // testy 
{
    cout << "max(3, 7) = " << ::max(3, 7) << "\n";

    int x = 10;
    int y = 25;
    int* bigger_ptr = ::max(&x, &y);
    cout << "wiekszy przez wskaznik = " << *bigger_ptr << "\n";

    int tab[] = {4, 9, 1, 13, 5};
    int* biggest_in_array = ::max(tab, 5);
    if (biggest_in_array != nullptr)
    {
        cout << "najwiekszy w tablicy = " << *biggest_in_array << "\n";
    }

    char a[] = "aaa";
    char b[] = "zzz";
    cout << "wiekszy napis char* = " << ::max(a, b) << "\n";

    const char* c = "banan";
    const char* d = "arbuz";
    cout << "wiekszy napis const char* = " << ::max(c, d) << "\n";

    cout << "wersja mieszana = " << ::max(a, "lama") << "\n";

    return 0;
}


