#include <functional>
#include <iostream>
#include <set>

int main()
{
    std::set<int, std::greater<int>> numbers;

    numbers.insert(7);
    numbers.insert(2);
    numbers.insert(10);
    numbers.insert(4);
    numbers.insert(10);
    numbers.insert(1);
    numbers.insert(8);

    std::cout << "Zbior posortowany malejaco:\n";
    for (int value : numbers)
    {
        std::cout << value << " ";
    }
    std::cout << "\n";

    std::cout << "Liczba elementow: " << numbers.size() << "\n";

    if (numbers.find(4) != numbers.end())
    {
        std::cout << "Element 4 znajduje sie w zbiorze\n";
    }
    else
    {
        std::cout << "Element 4 nie znajduje sie w zbiorze\n";
    }

    numbers.erase(7);

    std::cout << "Po usunieciu 7:\n";
    for (int value : numbers)
    {
        std::cout << value << " ";
    }
    std::cout << "\n";

    return 0;
}
