// dynamiczny polimorfizm


#include <iostream>

class Zwierze
{
public:
    virtual void dzwiek() = 0;
};

class Pies : public Zwierze
{
public:
    void dzwiek() override
    {
        std::cout << "Hau hau\n";
    }
};

class Kot : public Zwierze
{
public:
    void dzwiek() override
    {
        std::cout << "Miau\n";
    }
};

int main()
{
    Zwierze* z1 = new Pies();
    Zwierze* z2 = new Kot();

    z1->dzwiek();
    z2->dzwiek();

    delete z1;
    delete z2;

    return 0;
}

// program w trakcie działania sprawdza, czy to pies czy kot, następnie włącza właściwą wersję
