// statyczny polimorfizm

#include <iostream>

void pokaz(int x)
{
    std::cout << "int: " << x << "\n";
}

void pokaz(double x)
{
    std::cout << "double: " << x << "\n";
}

int main()
{
    pokaz(5);
    pokaz(3.14);
    return 0;
}

